<launch>
    <!-- 速腾 RoboSense：PointCloud2 需含 timestamp、ring（与 FAST-LIVO2 robosense_ros::Point 一致） -->
    <!-- 话题名默认见 config/robosense.yaml；播包前请改成与 bag 一致，或： -->
    <!--   rosparam set /common/lid_topic /your/lidar -->
    <!--   rosparam set /common/imu_topic /your/imu -->

    <arg name="rviz" default="true"/>
    <arg name="debug" default="false"/>

    <rosparam command="load" file="$(find btsa)/config/robosense.yaml"/>

    <group unless="$(arg debug)">
        <node pkg="btsa" type="btsa_node" name="btsa_node" output="screen"/>
    </group>
    <group if="$(arg debug)">
        <node pkg="btsa" type="btsa_node" name="btsa_node" output="screen"
              launch-prefix="/bin/bash $(find btsa)/scripts/run_under_gdb.sh"/>
    </group>

    <group if="$(arg rviz)">
        <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz"
              args="-d $(find btsa)/config/rviz_cfg/voxel_mapping.rviz"/>
    </group>

    <!-- 与 dynamic.launch 一致：默认启动「暂停」的 rosbag，空格后继续播；不用播包时：bag_file_use:=false -->
    <arg name="bag_file_use" default="true" />
    <arg name="bag_file" default="/home/kwanwaipang/datasets/multi_lidar_data.bag" />

    <param name="use_sim_time" value="false" />
    <group if="$(arg bag_file_use)">
        <node pkg="rosbag" type="play" name="rosbag"
              args="--clock --pause -r 1 -s 0 $(arg bag_file)" required="true"/>
    </group>
</launch>
